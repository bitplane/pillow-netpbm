# Atari DEGAS and NEOchrome bitmap detection rules
#
# These are extracted from the file/libmagic project's Magdir/images,
# with a fix to correctly distinguish NEOchrome from DEGAS Elite.
#
# The original rules misidentify all NEOchrome files as DEGAS Elite
# because both formats start with 0x0000 and the rules matched any
# 32128-byte file as DEGAS. NEOchrome is always exactly 32128 bytes
# (128-byte header + 32000 pixel data), while DEGAS uncompressed is
# 32034 and DEGAS Elite uncompressed is 32066.
#
# Patch submitted to libmagic: https://bugs.astron.com/view.php?id=XXX
#
# URL:		http://fileformats.archiveteam.org/wiki/DEGAS_image
# URL:		http://fileformats.archiveteam.org/wiki/NEOchrome
# Reference:	https://wiki.multimedia.cx/index.php?title=Degas
# Reference:	https://wiki.multimedia.cx/index.php?title=Neochrome

# DEGAS low-res uncompressed bitmap *.pi1
0		beshort		0x0000
>2		quad		!0
>>4		ubeshort&0xF000	0
# standard DEGAS low-res uncompressed bitmap *.pi1 with file size 32034
>>>-0		offset	=32034
>>>>0		use		degas-bitmap
# DEGAS Elite low-res uncompressed bitmap *.pi1 with file size 32066
>>>-0		offset	=32066
>>>>0		use		degas-bitmap
# file size 32128 is always Atari NEOchrome, not DEGAS.
>>>-0		offset	=32128
>>>>0		use		neochrome-bitmap
# DEGAS Elite low-res uncompressed bitmap *.pi1 with file size 44834
>>>-0		offset	=44834
>>>>0		use		degas-bitmap

# DEGAS mid-res uncompressed bitmap *.pi2
0		beshort		0x0001
>2		quad		!0
>>-0		offset	=32034
>>>0		use		degas-bitmap
>>-0		offset	=32066
>>>0		use		degas-bitmap

# DEGAS high-res uncompressed bitmap *.pi3
0		beshort		0x0002
>2		ubeshort&0xF000	0
>>-0		offset	=32034
>>>0		use		degas-bitmap
>>-0		offset	=32066
>>>0		use		degas-bitmap

# DEGAS low-res compressed bitmap *.pc1
0		beshort		0x8000
>2		ubeshort&0xF000	0
>>0		use		degas-bitmap

# DEGAS mid-res compressed bitmap *.pc2
0		beshort		0x8001
>2		ubeshort&0xF000	0
>>0		use		degas-bitmap

# DEGAS high-res compressed bitmap *.pc3
0		beshort		0x8002
>2		ubeshort&0xF000	0
>>0		use		degas-bitmap

# NEOchrome subroutine
0	name		neochrome-bitmap
>0	ubyte		x		Atari NEOchrome bitmap 320 x 200 x 16
!:mime	image/x-neo
!:ext	neo

# DEGAS subroutine
0	name		degas-bitmap
>0	ubyte		x		Atari DEGAS
!:mime	image/x-atari-degas
>0	ubyte		=0x80		Elite compressed
>0	ubyte		=0x00
>>32042	ubequad		x		Elite
>0	beshort		0x0000		bitmap
!:ext	pi1
>0	beshort		0x0001		bitmap
!:ext	pi2
>0	beshort		0x0002		bitmap
!:ext	pi3
>0	beshort		0x8000		bitmap
!:ext	pc1
>0	beshort		0x8001		bitmap
!:ext	pc2
>0	beshort		0x8002		bitmap
!:ext	pc3
>1	ubyte		=0		320 x 200 x 16
>1	ubyte		=1		640 x 200 x 4
>1	ubyte		=2		640 x 400 x 2
